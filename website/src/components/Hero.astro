---
// Hero — centered logo + single GitHub pill + headline + CTAs.
// Copy tracks back to README.md:3 (tagline) and README.md:12 (brew).
import icon from "../assets/icon.svg";
---

<section class="hero">
  <div class="container hero-inner">
    <img src={icon.src} alt="" class="hero-icon" width="72" height="72" />

    <h1 class="headline">
      Run AI coding agents<br />
      in real sandboxes.
    </h1>

    <p class="lede">
      Claude Code, Codex, and custom agents. Each in its own microVM.
    </p>

    <div class="cta-row">
      <a href="https://github.com/superhq-ai/superhq/releases" class="pill-btn primary">
        Download for MacOS <span class="arrow">→</span>
      </a>
      <button type="button" class="pill-btn install-cmd" data-copy="brew tap superhq-ai/tap && brew install --cask superhq" aria-label="Copy install command">
        <span class="prompt">$</span>
        <span class="cmd">brew tap superhq-ai/tap &amp;&amp; brew install --cask superhq</span>
        <span class="copy-icon" aria-hidden="true">
          <svg class="icon-copy" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="5" y="5" width="8" height="8" rx="1.5"/>
            <path d="M3 11V4a1 1 0 0 1 1-1h7"/>
          </svg>
          <svg class="icon-check" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 8.5l3.2 3.2L13 4.8"/>
          </svg>
        </span>
      </button>
    </div>

    <a
      class="ph-badge"
      href="https://www.producthunt.com/products/superhq?embed=true&utm_source=badge-featured&utm_medium=badge&utm_campaign=badge-superhq"
      target="_blank"
      rel="noopener noreferrer"
    >
      <img
        alt="SuperHQ - Run AI coding agents in real microVM sandboxes | Product Hunt"
        width="250"
        height="54"
        src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1122314&theme=dark&t=1776175673484"
      />
    </a>
  </div>
</section>

<style>
  .hero {
    padding-top: 100px;
    padding-bottom: 20px;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-icon {
    width: 72px;
    height: 72px;
    border-radius: 16px;
    margin-bottom: 44px;
  }

  .headline {
    max-width: 22ch;
    margin-bottom: 28px;
  }

  .ph-badge {
    display: inline-block;
    margin-top: 32px;
    line-height: 0;
  }

  .lede {
    max-width: 58ch;
    font-family: var(--sans);
    font-size: 1.02rem;
    line-height: 1.65;
    color: var(--fg-dim);
    margin-bottom: 40px;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .install-cmd {
    padding-left: 14px;
    padding-right: 14px;
    max-width: 100%;
  }
  .install-cmd .prompt { color: var(--fg-dimmer); margin-right: 2px; flex-shrink: 0; }
  .install-cmd .cmd {
    color: var(--fg);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  .install-cmd .copy-icon {
    position: relative;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    margin-left: 8px;
    padding-left: 10px;
    border-left: 1px solid var(--line-strong);
    box-sizing: content-box;
    color: var(--fg-dimmer);
  }
  .install-cmd .copy-icon svg {
    position: absolute;
    top: 0;
    left: 10px;
    width: 14px;
    height: 14px;
    transition: opacity 180ms ease, transform 180ms ease;
  }
  .install-cmd .icon-check {
    opacity: 0;
    transform: scale(0.6);
    color: var(--fg);
  }
  .install-cmd.copied .icon-copy {
    opacity: 0;
    transform: scale(0.6);
  }
  .install-cmd.copied .icon-check {
    opacity: 1;
    transform: scale(1);
  }
  .install-cmd:hover .copy-icon { color: var(--fg); }

  @media (max-width: 720px) {
    .hero { padding-top: 72px; }
  }
  @media (max-width: 640px) {
    .install-cmd { max-width: 92vw; }
    .install-cmd .cmd { max-width: 60vw; }
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>(".install-cmd");
  let resetTimer: ReturnType<typeof setTimeout> | undefined;

  btn?.addEventListener("click", async () => {
    const text = btn.dataset.copy ?? "";
    try {
      await navigator.clipboard.writeText(text);
      btn.classList.add("copied");
      if (resetTimer) clearTimeout(resetTimer);
      resetTimer = setTimeout(() => btn.classList.remove("copied"), 1600);
    } catch {
      /* noop */
    }
  });
</script>
